    <path class="draw u2" d="M 74.0 123.2 L 78.5 124.0 L 83.1 124.9 L 87.6 125.7 L 92.1 126.6 L 96.6 127.4 L 101.2 128.3 L 105.7 129.3 L 110.2 130.2 L 114.7 131.2 L 119.3 132.2 L 123.8 133.2 L 128.3 134.2 L 132.8 135.3 L 137.4 136.4 L 141.9 137.6 L 146.4 138.7 L 150.9 139.9 L 155.5 141.2 L 160.0 142.5 L 164.5 143.8 L 169.0 145.1 L 173.6 146.5 L 178.1 148.0 L 182.6 149.5 L 187.1 151.0 L 191.7 152.6 L 196.2 154.3 L 200.7 156.0 L 205.2 157.8 L 209.8 159.6 L 214.3 161.5 L 218.8 163.5 L 223.3 165.6 L 227.9 167.7 L 232.4 170.0 L 236.9 172.3 L 241.4 174.8 L 246.0 177.3 L 250.5 180.0 L 255.0 182.8 L 259.5 185.8 L 264.1 188.9 L 268.6 192.1 L 273.1 195.6 L 277.6 199.2 L 282.2 203.1 L 286.7 207.2 L 291.2 211.5 L 295.7 216.1 L 300.3 221.1 L 304.8 226.4 L 309.3 232.1 L 313.8 238.2 L 318.4 244.8 L 322.9 252.0 L 327.4 259.9 L 331.9 268.5 L 336.5 278.0 L 341.0 288.5" fill="none"
      stroke="var(--es-agent2)" stroke-width="1.6"/>

    <!-- budget line through endowment and equilibrium -->
    <path class="draw price" d="M 110.0 107.8 L 370.0 288.1" fill="none"
      stroke="var(--es-axis)" stroke-width="1" stroke-dasharray="4 4"/>

    <!-- endowment and equilibrium -->
    <circle cx="160.0" cy="142.5" r="4" fill="var(--es-equilibrium)"/>
    <circle cx="248.0" cy="203.5" r="4" fill="var(--es-equilibrium)"/>

    <!-- labels: italic serif, per the diagram conventions -->
    <g font-family="var(--es-font-body)" font-style="italic" font-size="14"
      fill="var(--es-ink)">
      <text x="36" y="316">O₁</text>
      <text x="416" y="26">O₂</text>
      <text x="100" y="312" font-size="12">x₁</text>
      <text x="32" y="256" font-size="12">y₁</text>
      <text x="352" y="28" font-size="12">x₂</text>
      <text x="418" y="86" font-size="12">y₂</text>
      <text x="164" y="134">ω</text>
      <text x="246" y="195">a*</text>
      <text x="120" y="74" fill="var(--es-agent1)">u₁</text>
      <text x="316" y="278" fill="var(--es-agent2)">u₂</text>
    </g>
  </svg>
  <figcaption class="fine">
    Color is notation on this site: <span style="color: var(--es-agent1)">person 1</span>,
    <span style="color: var(--es-agent2)">person 2</span>,
    <span style="color: var(--es-pareto)">the Pareto set</span>,
    <span style="color: var(--es-equilibrium)">endowment and equilibrium</span> — the
    same conventions across every diagram.
  </figcaption>
</figure>

<style>
  .edgeworth {
    margin: 0;
  }
  .edgeworth svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .edgeworth figcaption {
    margin-top: 0.6rem;
    line-height: 1.5;
  }
  /* Quiet draw-on when the page loads; disabled under prefers-reduced-motion
     by the global rule. */
  .draw {
    stroke-dasharray: 900;
    stroke-dashoffset: 900;
    animation: es-draw 1.4s ease-out forwards;
  }
  .u2    { animation-delay: 0.25s; }
  .cc    { animation-delay: 0.5s; }
  .price { animation-delay: 0.8s; }
  @keyframes es-draw {
    to { stroke-dashoffset: 0; }
  }
</style>
