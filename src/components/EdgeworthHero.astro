    <!-- box frame -->
    <rect x="50" y="35" width="360" height="260" fill="none"
      stroke="var(--es-axis)" stroke-width="1.1"/>

    <!-- axis direction arrows (agent 1, bottom-left; agent 2 reversed, top-right) -->
    <g stroke="var(--es-axis)" stroke-width="0.9" fill="var(--es-axis)">
      <line x1="50" y1="295" x2="96" y2="295"/><path d="M96 295 l-6 -2.4 v4.8 Z"/>
      <line x1="50" y1="295" x2="50" y2="252"/><path d="M50 252 l-2.4 6 h4.8 Z"/>
      <line x1="410" y1="35" x2="364" y2="35"/><path d="M364 35 l6 -2.4 v4.8 Z"/>
      <line x1="410" y1="35" x2="410" y2="78"/><path d="M410 78 l-2.4 -6 h4.8 Z"/>
    </g>

    <!-- contract curve (Pareto set) -->
    <path class="draw cc" d="M 52.0 294.4 L 58.0 292.4 L 64.1 290.4 L 70.1 288.3 L 76.1 286.3 L 82.2 284.1 L 88.2 282.0 L 94.2 279.8 L 100.3 277.5 L 106.3 275.2 L 112.3 272.9 L 118.4 270.5 L 124.4 268.0 L 130.4 265.5 L 136.5 263.0 L 142.5 260.4 L 148.5 257.7 L 154.6 255.0 L 160.6 252.2 L 166.6 249.3 L 172.7 246.4 L 178.7 243.4 L 184.7 240.4 L 190.8 237.3 L 196.8 234.1 L 202.8 230.8 L 208.9 227.4 L 214.9 224.0 L 220.9 220.5 L 227.0 216.8 L 233.0 213.1 L 239.1 209.3 L 245.1 205.4 L 251.1 201.4 L 257.2 197.3 L 263.2 193.0 L 269.2 188.7 L 275.3 184.2 L 281.3 179.6 L 287.3 174.8 L 293.4 169.9 L 299.4 164.9 L 305.4 159.7 L 311.5 154.3 L 317.5 148.8 L 323.5 143.1 L 329.6 137.2 L 335.6 131.1 L 341.6 124.8 L 347.7 118.3 L 353.7 111.5 L 359.7 104.6 L 365.8 97.3 L 371.8 89.8 L 377.8 82.0 L 383.9 73.9 L 389.9 65.5 L 395.9 56.8 L 402.0 47.7 L 408.0 38.2" fill="none"
      stroke="var(--es-pareto)" stroke-width="1.6"/>

    <!-- indifference curves through the endowment -->
    <path class="draw u1" d="M 128.0 39.5 L 132.6 60.8 L 137.3 79.2 L 141.9 95.4 L 146.6 109.6 L 151.2 122.2 L 155.9 133.4 L 160.5 143.5 L 165.2 152.6 L 169.8 160.8 L 174.4 168.2 L 179.1 175.0 L 183.7 181.2 L 188.4 186.9 L 193.0 192.1 L 197.7 196.9 L 202.3 201.4 L 206.9 205.5 L 211.6 209.3 L 216.2 212.9 L 220.9 216.2 L 225.5 219.3 L 230.2 222.2 L 234.8 225.0 L 239.5 227.5 L 244.1 229.9 L 248.7 232.2 L 253.4 234.3 L 258.0 236.4 L 262.7 238.3 L 267.3 240.1 L 272.0 241.8 L 276.6 243.4 L 281.3 245.0 L 285.9 246.4 L 290.5 247.8 L 295.2 249.2 L 299.8 250.4 L 304.5 251.7 L 309.1 252.8 L 313.8 253.9 L 318.4 255.0 L 323.1 256.0 L 327.7 257.0 L 332.3 257.9 L 337.0 258.8 L 341.6 259.7 L 346.3 260.5 L 350.9 261.3 L 355.6 262.1 L 360.2 262.8 L 364.8 263.5 L 369.5 264.2 L 374.1 264.8 L 378.8 265.5 L 383.4 266.1 L 388.1 266.7 L 392.7 267.3 L 397.4 267.8 L 402.0 268.4" fill="none"
