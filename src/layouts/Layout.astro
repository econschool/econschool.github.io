---
import '@fontsource/playfair-display/400.css';
import '@fontsource/playfair-display/700.css';
import '@fontsource/lora/400.css';
import '@fontsource/lora/700.css';
import '../styles/global.css';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href) => {
	const h = href.replace(/\/$/, '') || '/';
	return h === '/' ? path === '/' : (path === h || path.startsWith(h + '/'));
};
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Econschool</title>
	</head>
	<body>
		<header class="site-header">
			<div class="header-left">
				<a href="/" class="wordmark">Econschool</a>
				<nav class="main-nav" aria-label="Primary">
					<a href="/workshops/" aria-current={isActive('/workshops/') ? 'page' : undefined}>Workshops</a>
				</nav>
			</div>
			<a href="/" class="logo" aria-label="Econschool home">ES</a>
		</header>

		<main class="content">
			<slot />
		</main>

		<footer class="site-footer">
			<span>econschool.in</span>
			<nav class="footer-links">
				<a href="https://www.youtube.com/@econ.school">YouTube</a>
			</nav>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}

	body {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 760px;
		width: 100%;
		margin: 0 auto;
		padding: 1.5rem;
		box-sizing: border-box;
		border-bottom: 1px solid var(--es-sage);
	}

	.wordmark {
		font-family: var(--es-font-display);
		font-weight: 700;
		font-size: 1.5rem;
		color: var(--es-terracotta);
		text-decoration: none;
	}

	.header-left {
		display: flex;
		align-items: baseline;
		gap: 1.5rem;
	}

	.main-nav {
		display: flex;
		gap: 1.25rem;
	}

	.main-nav a {
		color: var(--es-ink);
		text-decoration: none;
	}

	.main-nav a:hover {
		color: var(--es-terracotta);
	}

	.main-nav a[aria-current="page"] {
		color: var(--es-terracotta);
		border-bottom: 2px solid var(--es-terracotta);
		padding-bottom: 2px;
	}
	.logo {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		background-color: var(--es-ink);
		color: var(--es-cream);
		font-family: var(--es-font-display);
		font-weight: 700;
		text-decoration: none;
		border-radius: 4px;
	}

	.content {
		flex: 1;
		max-width: 760px;
		width: 100%;
		margin: 0 auto;
		padding: 2rem 1.5rem;
		box-sizing: border-box;
	}

	.site-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 760px;
		width: 100%;
		margin: 0 auto;
		padding: 1.5rem;
		box-sizing: border-box;
		border-top: 1px solid var(--es-sage);
		font-size: 0.9rem;
		color: var(--es-gray);
	}

	.footer-links a {
		margin-left: 1rem;
	}
</style>