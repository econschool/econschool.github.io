---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const problems = (await getCollection('problems', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0));

const typeLabel = { solved: 'Solved problem', exercise: 'Exercise', tool: 'Interactive tool' };
---
<Layout title="Problems & Tools" width="wide">
  <div class="page-head">
    <span class="eyebrow">Problems &amp; Tools</span>
    <h1>Solve, check, and explore</h1>
    <p class="standfirst">
      Solved problems with every step shown, exercises to attempt unaided, and
      interactive tools. Attempt before you read — the struggle is the point.
    </p>
  </div>

  <ul class="postcard-grid">
    {problems.map((p) => (
      <li>
        <a class="postcard" href={`/problems/${p.id}/`}>
          <span class="card-sub">{typeLabel[p.data.type]}{p.data.level && ` · ${p.data.level}`}</span>
          <h3>{p.data.title}</h3>
          <hr class="card-rule" />
          <p class="card-body">{p.data.summary}</p>
          <span class="card-foot">
            <span>{p.data.topics.slice(0, 2).join(' · ')}</span>
            <span>Open →</span>
          </span>
        </a>
      </li>
    ))}
  </ul>
</Layout>
