---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const problems = await getCollection('problems', ({ data }) => !data.draft);
  return problems.map((p) => ({ params: { id: p.id }, props: { problem: p } }));
}

const { problem } = Astro.props;
const { Content } = await render(problem);
const typeLabel = { solved: 'Solved problem', exercise: 'Exercise', tool: 'Interactive tool' };
const isTool = problem.data.type === 'tool';
---
<Layout title={problem.data.title} description={problem.data.summary}>
  <div class="page-head">
    <span class="eyebrow">
      {typeLabel[problem.data.type]}{problem.data.level && ` · ${problem.data.level}`}
    </span>
    <h1>{problem.data.title}</h1>
    <p class="standfirst">{problem.data.summary}</p>
    {problem.data.source && <p class="fine">Source: {problem.data.source}</p>}
  </div>

  {isTool && problem.data.embed && (
    <div class="tool-frame" style={`--tool-h: ${problem.data.embedHeight ?? 600}px`}>
      <iframe
        src={problem.data.embed}
        title={problem.data.title}
        loading="lazy"
      ></iframe>
    </div>
  )}

  <Content />
</Layout>

<style>
  .tool-frame {
    border: 1px solid var(--es-sage);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 1.8rem;
    background: #fffdfa;
  }
  .tool-frame iframe {
    display: block;
    width: 100%;
    height: var(--tool-h);
    border: none;
  }
</style>
