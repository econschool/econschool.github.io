---
import Layout from '../../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const courses = await getCollection('courses', ({ data }) => !data.draft);
  const lessons = await getCollection('lessons', ({ data }) => !data.draft);

  return courses.flatMap((course) => {
    const courseLessons = lessons
      .filter((l) => l.id.startsWith(course.id + '/'))
      .sort((a, b) => a.data.order - b.data.order);

    return courseLessons.map((lesson, i) => ({
      params: { course: course.id, lesson: lesson.id.split('/').pop() },
      props: {
        course,
        lesson,
        prev: courseLessons[i - 1] ?? null,
        next: courseLessons[i + 1] ?? null,
      },
    }));
  });
}

const { course, lesson, prev, next } = Astro.props;
const { Content } = await render(lesson);
const slug = (l: { id: string }) => l.id.split('/').pop();
---
<Layout title={`${lesson.data.title} · ${course.data.title}`} width="prose">
  <div class="page-head">
    <span class="eyebrow">
      <a href={`/courses/${course.id}/`}>{course.data.title}</a>
    </span>
    <h1>{lesson.data.title}</h1>
    {lesson.data.summary && <p class="standfirst">{lesson.data.summary}</p>}
  </div>

  {lesson.data.youtube && (
    <div class="video">
      <iframe
        src={`https://www.youtube-nocookie.com/embed/${lesson.data.youtube}`}
        title={lesson.data.title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  )}

  <Content />

  <nav class="lesson-nav" aria-label="Lesson navigation">
    {prev ? (
      <a class="prev" href={`/courses/${course.id}/${slug(prev)}/`}>
        <span class="dir">← Previous</span>
        <span class="name">{prev.data.title}</span>
      </a>
    ) : <span />}
    {next ? (
      <a class="next" href={`/courses/${course.id}/${slug(next)}/`}>
        <span class="dir">Next →</span>
        <span class="name">{next.data.title}</span>
      </a>
    ) : <span />}
  </nav>

  <style>
    .video {
      position: relative;
      aspect-ratio: 16 / 9;
      margin: 0 0 1.8rem;
      border: 1px solid var(--es-sage);
    }
    .video iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }
    .lesson-nav {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 2.5rem;
      padding-top: 1.2rem;
      border-top: 1px solid var(--es-sage);
    }
    .lesson-nav a { display: flex; flex-direction: column; border-bottom: none; }
    .lesson-nav .next { text-align: right; margin-left: auto; }
    .lesson-nav .dir { font-size: 0.82rem; color: var(--es-terracotta); }
    .lesson-nav .name { color: var(--es-ink); font-weight: 600; }
    .lesson-nav a:hover .name { color: var(--es-terracotta); }
  </style>
</Layout>