---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Resources">
  <div class="page-head">
    <span class="eyebrow">Resources</span>
    <h1>The free library</h1>
    <p class="standfirst">
      Everything Econschool makes that you can use right now, at no cost.
    </p>
  </div>

  <h2>The YouTube channel</h2>
  <p>
    Lectures and problem-solving across microeconomic theory, game theory, 
    general equilibrium and rest of the graduate curriculum.
  </p>
  <p><a class="button secondary" href="https://www.youtube.com/@econ.school">Open the channel</a></p>

  <h2>The Econ Artbook</h2>
  <p>
    A hundred-page collection of mathematical postcards — one concept per card,
    drawn in TikZ and Mathcha. Made to be studied slowly, one card at a time.
  </p>
  <p><a class="button secondary" href="https://drive.google.com/file/d/14wg3_OtGJ-owK1W7NqbgdnqpF8ftPKMv/view?usp=share_link">Download the full PDF</a></p>

  <h2>Problems & Tools</h2>
  <p>
  Solved problems, exercises to attempt unaided, and interactive tools. <a href="/problems/">Problems &amp; Tools</a>.
  </p>

</Layout>
