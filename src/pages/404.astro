---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found">
  <div class="page-head">
    <span class="eyebrow">404</span>
    <h1>This page is outside the budget set</h1>
    <p class="standfirst">
      The address you followed does not exist — it may have moved when the site was
      rebuilt.
    </p>
  </div>
  <p>
    Try the <a href="/">homepage</a>, the <a href="/problems/">problem library</a>,
    or <a href="/start-here/">Start Here</a> if you are new.
  </p>
</Layout>
